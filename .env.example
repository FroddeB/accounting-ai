# ── e-conomic (proprietary two-token auth, NOT OAuth) ────────────────────────
# AppSecretToken: from your registered developer app (shown once).
# AgreementGrantToken: from installing that app against an agreement.
# For read-only sandbox testing you may use the literal value "demo" for both.
ECONOMIC_APP_SECRET_TOKEN=demo
ECONOMIC_AGREEMENT_GRANT_TOKEN=demo
ECONOMIC_API_BASE_REST=https://restapi.e-conomic.com
ECONOMIC_API_BASE_OPENAPI=https://apis.e-conomic.com

# ── Salary.dk (account-level API key) ────────────────────────────────────────
# Endpoint shapes still unconfirmed — see plan §2. Leave blank until a key is issued.
SALARY_API_KEY=
SALARY_API_BASE=https://api.salary.dk

# ── Database ─────────────────────────────────────────────────────────────────
# Provided automatically by the Railway Postgres plugin in production.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/accounting_ai

# ── MCP endpoint protection ──────────────────────────────────────────────────
# Shared secret. Clients must send: Authorization: Bearer <MCP_AUTH_TOKEN>
MCP_AUTH_TOKEN=change-me-to-a-long-random-string

# ── Safety ───────────────────────────────────────────────────────────────────
# When true, every write tool only simulates and records a dry_run audit entry.
DRY_RUN_DEFAULT=true

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
